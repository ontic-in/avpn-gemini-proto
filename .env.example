SITE_PIN=

# HMAC secret for signing the auth cookie — generate once with:
#   openssl rand -base64 32
PIN_COOKIE_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="AVPN AI Learning — Demo"
